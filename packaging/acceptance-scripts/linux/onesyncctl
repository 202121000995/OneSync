#!/bin/sh
set -eu

SERVICE=onesync.service
INSTALL_DIR=${ONESYNC_INSTALL_DIR:-/usr/local/bin}
COMMAND_LINK_DIR=${ONESYNC_COMMAND_LINK_DIR:-/usr/bin}
DATA_DIR=${ONESYNC_DATA_DIR:-/var/lib/onesync}
LOG_DIR=${ONESYNC_LOG_DIR:-/var/log/onesync}
PORT=${ONESYNC_PORT:-8765}
SYNC_PORT=${ONESYNC_SYNC_PORT:-7443}
WEB_BIND=${ONESYNC_WEB_BIND:-0.0.0.0}
REPO=${ONESYNC_REPO:-202121000995/OneSync}
DEFAULT_RELEASE_TAG=${ONESYNC_DEFAULT_RELEASE_TAG:-v1.07}
GH_PROXY=${GH_PROXY:-}
RELEASE_TAG=${ONESYNC_RELEASE_TAG:-${RELEASE_TAG:-}}
PACKAGE_URL=${ONESYNC_LINUX_PACKAGE_URL:-${PACKAGE_URL:-}}

need_root() {
	if [ "$(id -u)" -ne 0 ]; then
		printf 'Please run this command with sudo.\n' >&2
		exit 1
	fi
}

script_dir() {
	cd -- "$(dirname -- "$0")" && pwd
}

install_command_link() {
	name=$1
	target=$2
	if [ -d "$COMMAND_LINK_DIR" ] && [ "$COMMAND_LINK_DIR" != "$INSTALL_DIR" ]; then
		ln -sf "$target" "$COMMAND_LINK_DIR/$name"
	fi
}

install_command_links() {
	install_command_link onesync "$INSTALL_DIR/onesync"
	install_command_link onesyncctl "$INSTALL_DIR/onesyncctl"
}

remove_command_links() {
	if [ -d "$COMMAND_LINK_DIR" ] && [ "$COMMAND_LINK_DIR" != "$INSTALL_DIR" ]; then
		rm -f "$COMMAND_LINK_DIR/onesync" "$COMMAND_LINK_DIR/onesyncctl"
	fi
}

proxy_url() {
	url=$1
	if [ -z "$GH_PROXY" ]; then
		printf '%s' "$url"
		return
	fi
	case "$url" in
		"$GH_PROXY"*)
			printf '%s' "$url"
			return
			;;
	esac
	case "$GH_PROXY" in
		*/)
			printf '%s%s' "$GH_PROXY" "$url"
			;;
		*)
			printf '%s/%s' "$GH_PROXY" "$url"
			;;
	esac
}

latest_linux_package_url() {
	if [ -n "$PACKAGE_URL" ]; then
		printf '%s\n' "$PACKAGE_URL"
		return
	fi
	RELEASE_TAG=${RELEASE_TAG:-$DEFAULT_RELEASE_TAG}
	if [ -n "$RELEASE_TAG" ]; then
		case "$RELEASE_TAG" in
			acceptance-*)
				release_commit=${RELEASE_TAG#acceptance-}
				printf 'https://github.com/%s/releases/download/%s/onesync-acceptance-linux-amd64-%s.tar.gz\n' "$REPO" "$RELEASE_TAG" "$release_commit"
				;;
			*)
				printf 'https://github.com/%s/releases/download/%s/onesync-linux-amd64-%s.tar.gz\n' "$REPO" "$RELEASE_TAG" "$RELEASE_TAG"
				;;
		esac
		return
	fi
	api="https://api.github.com/repos/$REPO/releases/latest"
	curl -fsSL "$(proxy_url "$api")" |
		sed -n 's/.*"browser_download_url": "\(.*onesync.*linux-amd64.*\.tar\.gz\)".*/\1/p' |
		head -n 1
}

install_service() {
	need_root
	dir=$(script_dir)
	if [ ! -x "$dir/onesync" ]; then
		printf 'Cannot find executable %s/onesync. Run install from the extracted Linux package.\n' "$dir" >&2
		exit 1
	fi
	install -d "$INSTALL_DIR" "$DATA_DIR" "$LOG_DIR"
	install -m 0755 "$dir/onesync" "$INSTALL_DIR/onesyncd"
	if [ -x "$dir/onesync-menu" ]; then
		install -m 0755 "$dir/onesync-menu" "$INSTALL_DIR/onesync"
	fi
	if [ -x "$dir/onesync-cert" ]; then
		install -m 0755 "$dir/onesync-cert" "$INSTALL_DIR/onesync-cert"
	fi
	install -m 0755 "$0" "$INSTALL_DIR/onesyncctl"
	install_command_links
	cat > /etc/systemd/system/$SERVICE <<EOF
[Unit]
Description=OneSync service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=$INSTALL_DIR/onesyncd -data-dir $DATA_DIR -port $PORT -web-bind $WEB_BIND -web-auth -sync-port $SYNC_PORT -log-file $LOG_DIR/onesync.log
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF
	systemctl daemon-reload
	systemctl enable "$SERVICE"
	printf 'OneSync installed.\n'
	printf 'Menu command: onesync\n'
	printf 'Use: onesyncctl start|stop|restart|status|logs|upgrade|uninstall\n'
}

upgrade_service() {
	need_root
	if ! command -v curl >/dev/null 2>&1 || ! command -v tar >/dev/null 2>&1; then
		printf 'curl and tar are required for upgrade.\n' >&2
		exit 1
	fi
	tmp=${TMPDIR:-/tmp}/onesync-upgrade-$$
	mkdir -p "$tmp"
	trap 'rm -rf "$tmp"' EXIT
	url=$(latest_linux_package_url)
	if [ -z "$url" ]; then
		printf 'Cannot find latest Linux package from GitHub repo %s.\n' "$REPO" >&2
		printf 'Retry with RELEASE_TAG=v1.07 or PACKAGE_URL=https://...tar.gz.\n' >&2
		exit 1
	fi
	curl -fL "$(proxy_url "$url")" -o "$tmp/onesync-linux.tar.gz"
	tar -xzf "$tmp/onesync-linux.tar.gz" -C "$tmp"
	stage=$(find "$tmp" -maxdepth 1 -type d \( -name 'onesync-linux-amd64-*' -o -name 'onesync-acceptance-linux-amd64-*' \) | head -n 1)
	if [ -z "$stage" ]; then
		printf 'Downloaded package has no Linux stage directory.\n' >&2
		exit 1
	fi
	was_active=0
	if systemctl is-active --quiet "$SERVICE"; then
		was_active=1
		systemctl stop "$SERVICE"
	fi
	install -m 0755 "$stage/onesync" "$INSTALL_DIR/onesyncd"
	install -m 0755 "$stage/onesync-cert" "$INSTALL_DIR/onesync-cert"
	install -m 0755 "$stage/onesyncctl" "$INSTALL_DIR/onesyncctl"
	if [ -x "$stage/onesync-menu" ]; then
		install -m 0755 "$stage/onesync-menu" "$INSTALL_DIR/onesync"
	fi
	install_command_links
	if [ "$was_active" -eq 1 ]; then
		systemctl start "$SERVICE"
	fi
	printf 'OneSync upgraded from %s.\n' "$url"
	printf 'Menu command: onesync\n'
}

uninstall_service() {
	need_root
	systemctl stop "$SERVICE" 2>/dev/null || true
	systemctl disable "$SERVICE" 2>/dev/null || true
	rm -f /etc/systemd/system/$SERVICE
	systemctl daemon-reload
	rm -f "$INSTALL_DIR/onesyncd" "$INSTALL_DIR/onesyncctl" "$INSTALL_DIR/onesync"
	remove_command_links
	printf 'OneSync uninstalled. Data remains at %s and logs remain at %s.\n' "$DATA_DIR" "$LOG_DIR"
}

case "${1:-status}" in
	install)
		install_service
		;;
	start|run)
		need_root
		systemctl start "$SERVICE"
		;;
	stop)
		need_root
		systemctl stop "$SERVICE"
		;;
	restart)
		need_root
		systemctl restart "$SERVICE"
		;;
	status)
		systemctl status "$SERVICE" -l --no-pager
		;;
	logs)
		journalctl -u "$SERVICE" -n "${2:-120}" --no-pager
		;;
	upgrade)
		upgrade_service
		;;
	uninstall)
		uninstall_service
		;;
	*)
		printf 'Usage: onesyncctl install|start|run|stop|restart|status|logs|upgrade|uninstall\n' >&2
		exit 2
		;;
esac
