#!/bin/sh
set -eu

relay_installed=false

if command -v onesync-relayctl >/dev/null 2>&1; then
	relay_installed=true
fi

cat <<'EOF'
OneSync Relay 命令菜单

Relay TLS 中转服务：
  Relay 管理面板默认地址：http://服务器IP:8766
  首次访问会要求设置管理账号和密码。
EOF

if [ "$relay_installed" = true ]; then
	cat <<'EOF'
  sudo onesync-relayctl status    查看 Relay 运行状态
  sudo onesync-relayctl logs      查看 Relay 最近日志
  sudo onesync-relayctl info      一次性输出创建同步需要填写的地址、令牌和证书
  sudo onesync-relayctl token     查看生成链接时填写的 Relay 令牌
  sudo onesync-relayctl rotate-token
                                轮换 Relay 令牌并重启 Relay，旧链接会失效
  sudo onesync-relayctl cert      查看生成链接时可粘贴的 Relay 证书文本
  sudo onesync-relayctl cert-info 检查当前证书路径、有效期和私钥是否匹配
  sudo onesync-relayctl set-cert /path/fullchain.pem /path/privkey.pem
                                使用宝塔/1Panel/已有证书路径并重启 Relay
  sudo onesync-relayctl set-ports 17443 8766
                                修改 Relay 端口和管理面板端口并重启
  sudo RELAY_HOSTS=你的域名或IP RELAY_PORT=7443 onesync-relayctl regen-cert
                                重新生成匹配域名或 IP 的 Relay 证书
  sudo onesync-relayctl start     启动 Relay 服务
  sudo onesync-relayctl stop      停止 Relay 服务
  sudo onesync-relayctl restart   重启 Relay 和管理面板
  sudo onesync-relayctl upgrade   更新 Relay 到当前发布版本，默认不依赖 GitHub API
  sudo onesync-relayctl uninstall 卸载 Relay 服务，保留证书和日志
EOF
else
	cat <<'EOF'
  未安装 Relay。推荐一键部署：
  curl -fsSL https://raw.githubusercontent.com/202121000995/OneSync/main/packaging/acceptance-scripts/linux/deploy-relaytls.sh | sudo env RELAY_HOSTS=你的域名或IP RELAY_PORT=7443 RELAY_TOKEN=自定义令牌 sh

  中国大陆服务器可用代理：
  curl -fsSL https://gh-proxy.org/https://raw.githubusercontent.com/202121000995/OneSync/main/packaging/acceptance-scripts/linux/deploy-relaytls.sh | sudo env RELAY_HOSTS=你的域名或IP RELAY_PORT=7443 RELAY_TOKEN=自定义令牌 RELEASE_TAG=v1.27 GH_PROXY=https://gh-proxy.org/ sh
EOF
fi

cat <<'EOF'

提示：
  Relay TLS 地址格式是：域名或IP:端口
  例如：relay.example.com:7443
  已安装宝塔/1Panel 时，建议先在面板里申请并续期证书，再用 set-cert 填入证书和私钥路径。
  生成同步链接时可直接复制 info 输出；自建 Relay 使用自签证书时，需要把证书文本一起粘贴到 Relay 证书。
  目标端只粘贴同步链接即可。
  同步客户端菜单命令是：onesync
EOF
