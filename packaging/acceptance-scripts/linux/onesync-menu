#!/bin/sh
set -eu

client_installed=false

if command -v onesyncctl >/dev/null 2>&1; then
	client_installed=true
fi

cat <<'EOF'
OneSync 命令菜单

同步客户端：
EOF

if [ "$client_installed" = true ]; then
	cat <<'EOF'
  sudo onesyncctl status    查看客户端运行状态
  sudo onesyncctl logs      查看客户端最近日志
  sudo onesyncctl start     启动客户端服务
  sudo onesyncctl stop      停止客户端服务
  sudo onesyncctl restart   重启客户端服务
  sudo onesyncctl upgrade   更新客户端到当前发布版本，默认不依赖 GitHub API
  sudo onesyncctl uninstall 卸载客户端服务，保留数据和日志
EOF
else
	cat <<'EOF'
  未安装同步客户端。解压 Linux 包后可执行：
  sudo ./onesyncctl install

  或使用一键安装：
  curl -fsSL https://raw.githubusercontent.com/202121000995/OneSync/main/packaging/acceptance-scripts/linux/deploy-onesync.sh | sudo sh

  中国大陆服务器可用代理：
  curl -fsSL https://gh-proxy.org/https://raw.githubusercontent.com/202121000995/OneSync/main/packaging/acceptance-scripts/linux/deploy-onesync.sh | sudo env RELEASE_TAG=v1.28 GH_PROXY=https://gh-proxy.org/ sh
EOF
fi

cat <<'EOF'

提示：
  管理页默认地址是：http://服务器IP:8765
  第一次打开会要求设置管理账号和密码。
  Relay TLS 服务器菜单命令是：onesyncr
EOF
