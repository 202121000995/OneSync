#!/bin/sh
set -eu

client_installed=false
relay_installed=false

if command -v onesyncctl >/dev/null 2>&1; then
	client_installed=true
fi
if command -v onesync-relayctl >/dev/null 2>&1; then
	relay_installed=true
fi

cat <<'EOF'
OneSync 命令菜单

同步客户端：
EOF

if [ "$client_installed" = true ]; then
	cat <<'EOF'
  sudo onesyncctl status    查看客户端运行状态
  sudo onesyncctl logs      查看客户端最近日志
  sudo onesyncctl start     启动客户端服务
  sudo onesyncctl stop      停止客户端服务
  sudo onesyncctl restart   重启客户端服务
  sudo onesyncctl upgrade   更新客户端到 GitHub 最新版本
  sudo onesyncctl uninstall 卸载客户端服务，保留数据和日志
EOF
else
	cat <<'EOF'
  未安装同步客户端。解压 Linux 包后可执行：
  sudo ./onesyncctl install
EOF
fi

cat <<'EOF'

Relay TLS 中转服务：
EOF

if [ "$relay_installed" = true ]; then
	cat <<'EOF'
  sudo onesync-relayctl status    查看 Relay 运行状态
  sudo onesync-relayctl logs      查看 Relay 最近日志
  sudo onesync-relayctl start     启动 Relay 服务
  sudo onesync-relayctl stop      停止 Relay 服务
  sudo onesync-relayctl restart   重启 Relay 服务
  sudo onesync-relayctl upgrade   更新 Relay 到 GitHub 最新版本
  sudo onesync-relayctl uninstall 卸载 Relay 服务，保留证书和日志
EOF
else
	cat <<'EOF'
  未安装 Relay。推荐一键部署：
  curl -fsSL https://raw.githubusercontent.com/202121000995/OneSync/main/packaging/acceptance-scripts/linux/deploy-relaytls.sh | sudo env RELAY_HOSTS=你的域名或IP RELAY_PORT=7443 sh

  中国大陆服务器可用代理：
  curl -fsSL https://gh-proxy.org/https://raw.githubusercontent.com/202121000995/OneSync/main/packaging/acceptance-scripts/linux/deploy-relaytls.sh | sudo env RELAY_HOSTS=你的域名或IP RELAY_PORT=7443 GH_PROXY=https://gh-proxy.org/ sh
EOF
fi

cat <<'EOF'

提示：
  Relay TLS 地址格式是：域名或IP:端口
  例如：zz.31pk.top:7443
EOF
