#!/bin/sh
set -eu

SERVICE=onesync-relay.service
INSTALL_DIR=${ONESYNC_INSTALL_DIR:-/usr/local/bin}
COMMAND_LINK_DIR=${ONESYNC_COMMAND_LINK_DIR:-/usr/bin}
CONFIG_DIR=${ONESYNC_RELAY_CONFIG_DIR:-/etc/onesync}
LOG_DIR=${ONESYNC_LOG_DIR:-/var/log/onesync}
USER_SET_RELAY_PORT=${RELAY_PORT+x}
USER_SET_RELAY_LISTEN=${ONESYNC_RELAY_LISTEN+x}
USER_SET_RELAY_CERT=${ONESYNC_RELAY_CERT+x}
USER_SET_RELAY_KEY=${ONESYNC_RELAY_KEY+x}
USER_SET_RELAY_ADMIN_PORT=${ONESYNC_RELAY_ADMIN_PORT+x}
USER_SET_RELAY_ADMIN_LISTEN=${ONESYNC_RELAY_ADMIN_LISTEN+x}
RELAY_PORT=${RELAY_PORT:-7443}
LISTEN=${ONESYNC_RELAY_LISTEN:-:$RELAY_PORT}
CERT=${ONESYNC_RELAY_CERT:-$CONFIG_DIR/relay.crt}
KEY=${ONESYNC_RELAY_KEY:-$CONFIG_DIR/relay.key}
TOKEN_FILE=${ONESYNC_RELAY_TOKEN_FILE:-$CONFIG_DIR/relay.token}
ACCESS_KEYS_FILE=${ONESYNC_RELAY_ACCESS_KEYS_FILE:-$CONFIG_DIR/relay.keys.json}
ADDRESS_FILE=${ONESYNC_RELAY_ADDRESS_FILE:-$CONFIG_DIR/relay.address}
CERT_PATH_FILE=${ONESYNC_RELAY_CERT_PATH_FILE:-$CONFIG_DIR/relay.cert-paths}
ADMIN_LISTEN=${ONESYNC_RELAY_ADMIN_LISTEN:-0.0.0.0:${ONESYNC_RELAY_ADMIN_PORT:-8766}}
ADMIN_AUTH_FILE=${ONESYNC_RELAY_ADMIN_AUTH_FILE:-$CONFIG_DIR/relay-admin-auth.json}
REPO=${ONESYNC_REPO:-202121000995/OneSync}
DEFAULT_RELEASE_TAG=${ONESYNC_DEFAULT_RELEASE_TAG:-v1.17}
GH_PROXY=${GH_PROXY:-}
RELEASE_TAG=${ONESYNC_RELEASE_TAG:-${RELEASE_TAG:-}}
PACKAGE_URL=${ONESYNC_LINUX_PACKAGE_URL:-${PACKAGE_URL:-}}

if [ -f "$CERT_PATH_FILE" ] && [ -z "${ONESYNC_RELAY_CERT:-}" ] && [ -z "${ONESYNC_RELAY_KEY:-}" ]; then
	saved_cert=$(sed -n '1p' "$CERT_PATH_FILE")
	saved_key=$(sed -n '2p' "$CERT_PATH_FILE")
	if [ -n "$saved_cert" ] && [ -n "$saved_key" ]; then
		CERT=$saved_cert
		KEY=$saved_key
	fi
fi

need_root() {
	if [ "$(id -u)" -ne 0 ]; then
		printf 'Please run this command with sudo.\n' >&2
		exit 1
	fi
}

script_dir() {
	cd -- "$(dirname -- "$0")" && pwd
}

install_command_link() {
	name=$1
	target=$2
	if [ -d "$COMMAND_LINK_DIR" ] && [ "$COMMAND_LINK_DIR" != "$INSTALL_DIR" ]; then
		ln -sf "$target" "$COMMAND_LINK_DIR/$name"
	fi
}

install_command_links() {
	install_command_link onesyncr "$INSTALL_DIR/onesyncr"
	install_command_link onesync-relayctl "$INSTALL_DIR/onesync-relayctl"
}

remove_command_links() {
	if [ -d "$COMMAND_LINK_DIR" ] && [ "$COMMAND_LINK_DIR" != "$INSTALL_DIR" ]; then
		rm -f "$COMMAND_LINK_DIR/onesyncr" "$COMMAND_LINK_DIR/onesync-relayctl"
	fi
}

proxy_url() {
	url=$1
	if [ -z "$GH_PROXY" ]; then
		printf '%s' "$url"
		return
	fi
	case "$url" in
		"$GH_PROXY"*)
			printf '%s' "$url"
			return
			;;
	esac
	case "$GH_PROXY" in
		*/)
			printf '%s%s' "$GH_PROXY" "$url"
			;;
		*)
			printf '%s/%s' "$GH_PROXY" "$url"
			;;
	esac
}

current_service_arg() {
	key=$1
	line=$(systemctl cat "$SERVICE" 2>/dev/null | sed -n 's/^ExecStart=//p' | tail -n 1 || true)
	if [ -z "$line" ]; then
		return
	fi
	set -- $line
	while [ "$#" -gt 0 ]; do
		if [ "$1" = "$key" ] && [ "$#" -gt 1 ]; then
			printf '%s\n' "$2"
			return
		fi
		shift
	done
}

preserve_current_service_options() {
	if [ -z "$USER_SET_RELAY_LISTEN" ] && [ -z "$USER_SET_RELAY_PORT" ]; then
		current=$(current_service_arg -listen || true)
		if [ -n "$current" ]; then
			LISTEN=$current
		fi
	fi
	if [ -z "$USER_SET_RELAY_CERT" ]; then
		current=$(current_service_arg -cert || true)
		if [ -n "$current" ]; then
			CERT=$current
		fi
	fi
	if [ -z "$USER_SET_RELAY_KEY" ]; then
		current=$(current_service_arg -key || true)
		if [ -n "$current" ]; then
			KEY=$current
		fi
	fi
	if [ -z "$USER_SET_RELAY_ADMIN_LISTEN" ] && [ -z "$USER_SET_RELAY_ADMIN_PORT" ]; then
		current=$(current_service_arg -admin-listen || true)
		if [ -n "$current" ]; then
			ADMIN_LISTEN=$current
		fi
	fi
}

latest_linux_package_url() {
	if [ -n "$PACKAGE_URL" ]; then
		printf '%s\n' "$PACKAGE_URL"
		return
	fi
	RELEASE_TAG=${RELEASE_TAG:-$DEFAULT_RELEASE_TAG}
	if [ -n "$RELEASE_TAG" ]; then
		case "$RELEASE_TAG" in
			acceptance-*)
				release_commit=${RELEASE_TAG#acceptance-}
				printf 'https://github.com/%s/releases/download/%s/onesync-acceptance-linux-amd64-%s.tar.gz\n' "$REPO" "$RELEASE_TAG" "$release_commit"
				;;
			*)
				printf 'https://github.com/%s/releases/download/%s/onesync-linux-amd64-%s.tar.gz\n' "$REPO" "$RELEASE_TAG" "$RELEASE_TAG"
				;;
		esac
		return
	fi
	api="https://api.github.com/repos/$REPO/releases/latest"
	curl -fsSL "$(proxy_url "$api")" |
		sed -n 's/.*"browser_download_url": "\(.*onesync.*linux-amd64.*\.tar\.gz\)".*/\1/p' |
		head -n 1
}

default_hosts() {
	host=$(hostname -f 2>/dev/null || hostname 2>/dev/null || printf relay.local)
	printf '%s,127.0.0.1,localhost' "$host"
}

first_host() {
	printf '%s' "$1" | cut -d, -f1
}

listen_port() {
	printf '%s' "$LISTEN" | sed 's/.*://'
}

admin_port() {
	printf '%s' "$ADMIN_LISTEN" | sed 's/.*://'
}

validate_port() {
	name=$1
	value=$2
	case "$value" in
		''|*[!0-9]*)
			printf '%s must be a number between 1 and 65535.\n' "$name" >&2
			exit 2
			;;
	esac
	if [ "$value" -lt 1 ] || [ "$value" -gt 65535 ]; then
		printf '%s must be between 1 and 65535.\n' "$name" >&2
		exit 2
	fi
}

listen_with_port() {
	listen=$1
	port=$2
	case "$listen" in
		*:*)
			host=${listen%:*}
			printf '%s:%s' "$host" "$port"
			;;
		*)
			printf ':%s' "$port"
			;;
	esac
}

save_cert_paths() {
	install -d "$CONFIG_DIR"
	printf '%s\n%s\n' "$CERT" "$KEY" > "$CERT_PATH_FILE"
	chmod 0644 "$CERT_PATH_FILE"
}

save_relay_address() {
	hosts=${1:-}
	if [ -z "$hosts" ]; then
		return
	fi
	printf '%s:%s\n' "$(first_host "$hosts")" "$(listen_port)" > "$ADDRESS_FILE"
	chmod 0644 "$ADDRESS_FILE"
}

generate_token() {
	if command -v openssl >/dev/null 2>&1; then
		openssl rand -base64 32 | tr -d '\n'
		return
	fi
	if command -v od >/dev/null 2>&1; then
		od -An -tx1 -N32 /dev/urandom | tr -d ' \n'
		return
	fi
	printf 'openssl or od is required to generate RELAY_TOKEN.\n' >&2
	exit 1
}

install_token() {
	if [ -n "${RELAY_TOKEN:-}" ]; then
		printf '%s\n' "$RELAY_TOKEN" > "$TOKEN_FILE"
		chmod 0600 "$TOKEN_FILE"
		printf 'Saved Relay access token to %s\n' "$TOKEN_FILE"
		return
	fi
	if [ ! -f "$TOKEN_FILE" ]; then
		generate_token > "$TOKEN_FILE"
		printf '\n' >> "$TOKEN_FILE"
		chmod 0600 "$TOKEN_FILE"
		printf 'Generated Relay access token at %s\n' "$TOKEN_FILE"
	else
		chmod 0600 "$TOKEN_FILE"
		printf 'Using existing Relay access token: %s\n' "$TOKEN_FILE"
	fi
}

print_token() {
	need_root
	if [ ! -f "$TOKEN_FILE" ]; then
		printf 'Relay token file does not exist: %s\n' "$TOKEN_FILE" >&2
		exit 1
	fi
	printf 'Relay token:\n'
	cat "$TOKEN_FILE"
	printf '\n'
}

print_cert() {
	need_root
	if [ ! -f "$CERT" ]; then
		printf 'Relay certificate file does not exist: %s\n' "$CERT" >&2
		exit 1
	fi
	printf 'Relay certificate PEM:\n'
	cat "$CERT"
	printf '\n'
}

cert_managed_by_onesync() {
	case "$CERT" in
		"$CONFIG_DIR"/*)
			return 0
			;;
	esac
	return 1
}

cert_summary() {
	cert_path=${1:-$CERT}
	key_path=${2:-$KEY}
	if [ ! -f "$cert_path" ]; then
		printf 'Relay certificate file does not exist: %s\n' "$cert_path" >&2
		return 1
	fi
	if [ ! -f "$key_path" ]; then
		printf 'Relay private key file does not exist: %s\n' "$key_path" >&2
		return 1
	fi
	if [ ! -r "$cert_path" ] || [ ! -r "$key_path" ]; then
		printf 'Relay certificate or private key is not readable. Check permissions: %s %s\n' "$cert_path" "$key_path" >&2
		return 1
	fi
	printf 'Relay certificate path: %s\n' "$cert_path"
	printf 'Relay private key path: %s\n' "$key_path"
	if command -v openssl >/dev/null 2>&1; then
		openssl x509 -in "$cert_path" -noout -subject -issuer -dates 2>/dev/null || {
			printf 'Certificate is not a valid PEM X.509 certificate: %s\n' "$cert_path" >&2
			return 1
		}
		if openssl x509 -in "$cert_path" -pubkey -noout 2>/dev/null | openssl sha256 >/tmp/onesync-cert-pub.$$ 2>/dev/null &&
			openssl pkey -in "$key_path" -pubout 2>/dev/null | openssl sha256 >/tmp/onesync-key-pub.$$ 2>/dev/null; then
			if cmp -s /tmp/onesync-cert-pub.$$ /tmp/onesync-key-pub.$$; then
				printf 'Certificate and private key match.\n'
			else
				rm -f /tmp/onesync-cert-pub.$$ /tmp/onesync-key-pub.$$
				printf 'Certificate and private key do not match.\n' >&2
				return 1
			fi
			rm -f /tmp/onesync-cert-pub.$$ /tmp/onesync-key-pub.$$
		else
			rm -f /tmp/onesync-cert-pub.$$ /tmp/onesync-key-pub.$$
			printf 'Cannot verify whether certificate and private key match.\n' >&2
			return 1
		fi
	else
		printf 'openssl is not installed; skipped certificate detail checks.\n'
	fi
}

test_cert() {
	need_root
	cert_summary "$CERT" "$KEY"
}

print_info() {
	need_root
	address='<Relay domain or IP>:'"$(listen_port)"
	if [ -f "$ADDRESS_FILE" ]; then
		address=$(sed -n '1p' "$ADDRESS_FILE")
	fi
	printf 'OneSync Relay 创建同步需要填写的文本\n\n'
	printf 'Relay 地址:\n%s\n\n' "$address"
	printf 'Relay 令牌:\n'
	if [ ! -f "$TOKEN_FILE" ]; then
		printf 'Relay token file does not exist: %s\n' "$TOKEN_FILE" >&2
		exit 1
	fi
	cat "$TOKEN_FILE"
	printf '\n\n'
	printf 'Relay 证书（自建自签 Relay 时填写；公网可信证书通常不用填）:\n'
	if [ ! -f "$CERT" ]; then
		printf 'Relay certificate file does not exist: %s\n' "$CERT" >&2
		exit 1
	fi
	cat "$CERT"
	printf '\n'
	printf 'Relay 管理面板:\nhttp://<服务器IP或域名>:%s\n\n' "$(printf '%s' "$ADMIN_LISTEN" | sed 's/.*://')"
}

write_service_unit() {
	cat > /etc/systemd/system/$SERVICE <<EOF
[Unit]
Description=OneSync Relay service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=$INSTALL_DIR/onesync-relay -listen $LISTEN -cert $CERT -key $KEY -cert-path-file $CERT_PATH_FILE -access-token-file $TOKEN_FILE -access-keys-file $ACCESS_KEYS_FILE -log-file $LOG_DIR/relay.log -admin-listen $ADMIN_LISTEN -admin-auth-file $ADMIN_AUTH_FILE
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF
}

set_cert_paths() {
	need_root
	if [ $# -lt 2 ]; then
		printf 'Usage: sudo onesync-relayctl set-cert /path/fullchain.pem /path/privkey.pem\n' >&2
		printf 'For BT/1Panel, use the certificate and private key paths generated by the panel.\n' >&2
		exit 2
	fi
	CERT=$1
	KEY=$2
	cert_summary "$CERT" "$KEY"
	save_cert_paths
	write_service_unit
	systemctl daemon-reload
	printf 'Relay certificate paths saved.\n'
	if systemctl is-active --quiet "$SERVICE"; then
		systemctl restart "$SERVICE"
		printf 'Relay service restarted.\n'
	fi
	print_info
}

set_ports() {
	need_root
	if [ $# -lt 2 ]; then
		printf 'Usage: sudo onesync-relayctl set-ports RELAY_PORT PANEL_PORT\n' >&2
		printf 'Example: sudo onesync-relayctl set-ports 17443 8766\n' >&2
		exit 2
	fi
	relay_port=$1
	panel_port=$2
	validate_port "RELAY_PORT" "$relay_port"
	validate_port "PANEL_PORT" "$panel_port"
	preserve_current_service_options
	LISTEN=$(listen_with_port "$LISTEN" "$relay_port")
	ADMIN_LISTEN=$(listen_with_port "$ADMIN_LISTEN" "$panel_port")
	save_cert_paths
	write_service_unit
	systemctl daemon-reload
	printf 'Relay port saved: %s\n' "$LISTEN"
	printf 'Relay admin panel port saved: %s\n' "$ADMIN_LISTEN"
	if systemctl is-active --quiet "$SERVICE"; then
		systemctl restart "$SERVICE"
		printf 'Relay service restarted.\n'
	fi
	print_info
}

rotate_token() {
	need_root
	if [ -f "$TOKEN_FILE" ]; then
		cp "$TOKEN_FILE" "$TOKEN_FILE.bak.$(date +%Y%m%d%H%M%S)"
	fi
	generate_token > "$TOKEN_FILE"
	printf '\n' >> "$TOKEN_FILE"
	chmod 0600 "$TOKEN_FILE"
	printf 'Relay access token rotated.\n'
	if systemctl is-active --quiet "$SERVICE"; then
		systemctl restart "$SERVICE"
		printf 'Relay service restarted.\n'
	fi
	print_info
}

regenerate_cert() {
	need_root
	if [ -z "${RELAY_HOSTS:-}" ]; then
		printf 'RELAY_HOSTS is required. Example:\n' >&2
		printf '  sudo RELAY_HOSTS=r.example.com RELAY_PORT=17443 onesync-relayctl regen-cert\n' >&2
		exit 1
	fi
	if [ ! -x "$INSTALL_DIR/onesync-cert" ]; then
		printf 'Cannot find %s/onesync-cert. Reinstall or upgrade OneSync Relay first.\n' "$INSTALL_DIR" >&2
		exit 1
	fi
	if ! cert_managed_by_onesync && [ "${ONESYNC_ALLOW_OVERWRITE_CERT:-}" != "1" ]; then
		printf 'Current Relay certificate path looks external: %s\n' "$CERT" >&2
		printf 'Refusing to overwrite a BT/1Panel/custom certificate. Use set-cert to change paths, or run with ONESYNC_ALLOW_OVERWRITE_CERT=1 if you really want to overwrite it.\n' >&2
		exit 1
	fi
	was_active=0
	if systemctl is-active --quiet "$SERVICE"; then
		was_active=1
		systemctl stop "$SERVICE"
	fi
	backup_suffix=$(date +%Y%m%d%H%M%S)
	if [ -f "$CERT" ]; then
		cp "$CERT" "$CERT.bak.$backup_suffix"
	fi
	if [ -f "$KEY" ]; then
		cp "$KEY" "$KEY.bak.$backup_suffix"
	fi
	"$INSTALL_DIR/onesync-cert" -hosts "$RELAY_HOSTS" -cert "$CERT" -key "$KEY"
	chmod 0600 "$KEY"
	save_relay_address "$RELAY_HOSTS"
	if [ "$was_active" -eq 1 ]; then
		systemctl start "$SERVICE"
	fi
	printf 'Relay TLS certificate regenerated for: %s\n' "$RELAY_HOSTS"
	print_info
}

install_service() {
	need_root
	dir=$(script_dir)
	if [ ! -x "$dir/onesync-relay" ] || [ ! -x "$dir/onesync-cert" ]; then
		printf 'Cannot find onesync-relay and onesync-cert. Run install from the extracted Linux package.\n' >&2
		exit 1
	fi
	install -d "$INSTALL_DIR" "$CONFIG_DIR" "$LOG_DIR"
	install -m 0755 "$dir/onesync-relay" "$INSTALL_DIR/onesync-relay"
	install -m 0755 "$dir/onesync-cert" "$INSTALL_DIR/onesync-cert"
	install -m 0755 "$0" "$INSTALL_DIR/onesync-relayctl"
	if [ -x "$dir/onesyncr-menu" ]; then
		install -m 0755 "$dir/onesyncr-menu" "$INSTALL_DIR/onesyncr"
	fi
	install_command_links
	if [ ! -x "$INSTALL_DIR/onesyncctl" ]; then
		rm -f "$INSTALL_DIR/onesync"
	fi
	hosts=${RELAY_HOSTS:-}
	if [ ! -f "$CERT" ] || [ ! -f "$KEY" ]; then
		hosts=${hosts:-$(default_hosts)}
		"$INSTALL_DIR/onesync-cert" -hosts "$hosts" -cert "$CERT" -key "$KEY"
		chmod 0600 "$KEY"
		printf 'Generated Relay TLS certificate for: %s\n' "$hosts"
	else
		printf 'Using existing Relay TLS certificate: %s and %s\n' "$CERT" "$KEY"
	fi
	save_cert_paths
	if [ -n "$hosts" ]; then
		save_relay_address "$hosts"
	fi
	install_token
	write_service_unit
	systemctl daemon-reload
	systemctl enable "$SERVICE"
	printf 'OneSync Relay installed on %s.\n' "$LISTEN"
	print_info
	printf 'Menu command: onesyncr\n'
	printf 'Relay admin panel: http://<server-ip>:%s\n' "$(printf '%s' "$ADMIN_LISTEN" | sed 's/.*://')"
	printf 'Use: onesync-relayctl start|stop|restart|status|logs|info|token|rotate-token|cert|cert-info|test-cert|set-cert|set-ports|regen-cert|upgrade|uninstall\n'
}

upgrade_service() {
	need_root
	if ! command -v curl >/dev/null 2>&1 || ! command -v tar >/dev/null 2>&1; then
		printf 'curl and tar are required for upgrade.\n' >&2
		exit 1
	fi
	tmp=${TMPDIR:-/tmp}/onesync-relay-upgrade-$$
	mkdir -p "$tmp"
	trap 'rm -rf "$tmp"' EXIT
	url=$(latest_linux_package_url)
	if [ -z "$url" ]; then
		printf 'Cannot find latest Linux package from GitHub repo %s.\n' "$REPO" >&2
		printf 'Retry with RELEASE_TAG=v1.17 or PACKAGE_URL=https://...tar.gz.\n' >&2
		exit 1
	fi
	curl -fL "$(proxy_url "$url")" -o "$tmp/onesync-linux.tar.gz"
	tar -xzf "$tmp/onesync-linux.tar.gz" -C "$tmp"
	stage=$(find "$tmp" -maxdepth 1 -type d \( -name 'onesync-linux-amd64-*' -o -name 'onesync-acceptance-linux-amd64-*' \) | head -n 1)
	if [ -z "$stage" ]; then
		printf 'Downloaded package has no Linux stage directory.\n' >&2
		exit 1
	fi
	was_active=0
	if systemctl is-active --quiet "$SERVICE"; then
		was_active=1
		systemctl stop "$SERVICE"
	fi
	install -m 0755 "$stage/onesync-relay" "$INSTALL_DIR/onesync-relay"
	install -m 0755 "$stage/onesync-cert" "$INSTALL_DIR/onesync-cert"
	install -m 0755 "$stage/onesync-relayctl" "$INSTALL_DIR/onesync-relayctl"
	if [ -x "$stage/onesyncr-menu" ]; then
		install -m 0755 "$stage/onesyncr-menu" "$INSTALL_DIR/onesyncr"
	fi
	install_command_links
	if [ ! -x "$INSTALL_DIR/onesyncctl" ]; then
		rm -f "$INSTALL_DIR/onesync"
	fi
	preserve_current_service_options
	save_cert_paths
	write_service_unit
	systemctl daemon-reload
	if [ "$was_active" -eq 1 ]; then
		systemctl start "$SERVICE"
	fi
	printf 'OneSync Relay upgraded from %s.\n' "$url"
	printf 'Menu command: onesyncr\n'
	printf 'Relay admin panel: http://<server-ip>:%s\n' "$(printf '%s' "$ADMIN_LISTEN" | sed 's/.*://')"
}

uninstall_service() {
	need_root
	systemctl stop "$SERVICE" 2>/dev/null || true
	systemctl disable "$SERVICE" 2>/dev/null || true
	rm -f /etc/systemd/system/$SERVICE
	systemctl daemon-reload
	rm -f "$INSTALL_DIR/onesync-relay" "$INSTALL_DIR/onesync-relayctl" "$INSTALL_DIR/onesyncr"
	remove_command_links
	printf 'OneSync Relay uninstalled. Certificate and token remain at %s and logs remain at %s.\n' "$CONFIG_DIR" "$LOG_DIR"
}

case "${1:-status}" in
	install)
		install_service
		;;
	start|run)
		need_root
		systemctl start "$SERVICE"
		;;
	stop)
		need_root
		systemctl stop "$SERVICE"
		;;
	restart)
		need_root
		systemctl restart "$SERVICE"
		;;
	status)
		systemctl status "$SERVICE" -l --no-pager
		;;
	logs)
		journalctl -u "$SERVICE" -n "${2:-120}" --no-pager
		;;
	token)
		print_token
		;;
	rotate-token)
		rotate_token
		;;
	cert|certificate)
		print_cert
		;;
	cert-info|test-cert)
		test_cert
		;;
	set-cert)
		shift
		set_cert_paths "$@"
		;;
	set-ports)
		shift
		set_ports "$@"
		;;
	info|link|link-info)
		print_info
		;;
	regen-cert|regenerate-cert)
		regenerate_cert
		;;
	upgrade)
		upgrade_service
		;;
	uninstall)
		uninstall_service
		;;
	*)
		printf 'Usage: onesync-relayctl install|start|run|stop|restart|status|logs|info|token|rotate-token|cert|cert-info|test-cert|set-cert|set-ports|regen-cert|upgrade|uninstall\n' >&2
		printf 'Install options: RELAY_HOSTS=domain-or-ip RELAY_PORT=7443 RELAY_TOKEN=secret ONESYNC_RELAY_CERT=/path/fullchain.pem ONESYNC_RELAY_KEY=/path/privkey.pem\n' >&2
		exit 2
		;;
esac
